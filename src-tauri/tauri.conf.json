{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Open Grind Premium",
  "version": "0.1.0-alpha.19",
  "identifier": "com.opengrind.premium",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Open Grind Premium",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "autoIncrementVersionCode": false,
      "minSdkVersion": 28,
      "versionCode": 1006
    }
  }
}
